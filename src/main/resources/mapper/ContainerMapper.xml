<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hospital.waste.mapper.ContainerMapper">

    <resultMap id="BaseResultMap" type="com.hospital.waste.entity.Container">
        <id column="id" property="id"/>
        <result column="container_code" property="containerCode"/>
        <result column="container_type" property="containerType"/>
        <result column="specification" property="specification"/>
        <result column="capacity" property="capacity"/>
        <result column="department_id" property="departmentId"/>
        <result column="current_count" property="currentCount"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT * FROM container ORDER BY id DESC
    </select>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM container WHERE id = #{id}
    </select>

    <select id="selectByCode" resultMap="BaseResultMap">
        SELECT * FROM container WHERE container_code = #{containerCode}
    </select>

    <select id="selectByDepartmentId" resultMap="BaseResultMap">
        SELECT * FROM container WHERE department_id = #{departmentId}
    </select>

    <select id="selectByStatus" resultMap="BaseResultMap">
        SELECT * FROM container WHERE status = #{status}
    </select>

    <insert id="insert" parameterType="com.hospital.waste.entity.Container" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO container (container_code, container_type, specification, capacity, department_id, current_count, status, create_time, update_time)
        VALUES (#{containerCode}, #{containerType}, #{specification}, #{capacity}, #{departmentId}, #{currentCount}, #{status}, NOW(), NOW())
    </insert>

    <update id="update" parameterType="com.hospital.waste.entity.Container">
        UPDATE container
        SET container_code = #{containerCode},
            container_type = #{containerType},
            specification = #{specification},
            capacity = #{capacity},
            department_id = #{departmentId},
            current_count = #{currentCount},
            status = #{status},
            update_time = NOW()
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM container WHERE id = #{id}
    </delete>

</mapper>
