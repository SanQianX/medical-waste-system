<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hospital.waste.mapper.WasteCategoryMapper">

    <resultMap id="BaseResultMap" type="com.hospital.waste.entity.WasteCategory">
        <id column="id" property="id"/>
        <result column="category_code" property="categoryCode"/>
        <result column="category_name" property="categoryName"/>
        <result column="category_type" property="categoryType"/>
        <result column="description" property="description"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT * FROM base_waste_category ORDER BY create_time DESC
    </select>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM base_waste_category WHERE id = #{id}
    </select>

    <select id="selectByCategoryCode" resultMap="BaseResultMap">
        SELECT * FROM base_waste_category WHERE category_code = #{categoryCode}
    </select>

    <select id="selectByStatus" resultMap="BaseResultMap">
        SELECT * FROM base_waste_category WHERE status = #{status}
    </select>

    <insert id="insert" parameterType="com.hospital.waste.entity.WasteCategory" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO base_waste_category (category_code, category_name, category_type, description, status, create_time)
        VALUES (#{categoryCode}, #{categoryName}, #{categoryType}, #{description}, #{status}, NOW())
    </insert>

    <update id="update" parameterType="com.hospital.waste.entity.WasteCategory">
        UPDATE base_waste_category
        <set>
            <if test="categoryCode != null">category_code = #{categoryCode},</if>
            <if test="categoryName != null">category_name = #{categoryName},</if>
            <if test="categoryType != null">category_type = #{categoryType},</if>
            <if test="description != null">description = #{description},</if>
            <if test="status != null">status = #{status},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM base_waste_category WHERE id = #{id}
    </delete>

</mapper>
