<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hospital.waste.mapper.SysRoleMapper">

    <resultMap id="BaseResultMap" type="com.hospital.waste.entity.SysRole">
        <id column="id" property="id"/>
        <result column="role_name" property="roleName"/>
        <result column="role_code" property="roleCode"/>
        <result column="description" property="description"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT * FROM sys_role ORDER BY create_time DESC
    </select>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM sys_role WHERE id = #{id}
    </select>

    <select id="selectByRoleCode" resultMap="BaseResultMap">
        SELECT * FROM sys_role WHERE role_code = #{roleCode}
    </select>

    <insert id="insert" parameterType="com.hospital.waste.entity.SysRole" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sys_role (role_name, role_code, description, create_time)
        VALUES (#{roleName}, #{roleCode}, #{description}, NOW())
    </insert>

    <update id="update" parameterType="com.hospital.waste.entity.SysRole">
        UPDATE sys_role
        <set>
            <if test="roleName != null">role_name = #{roleName},</if>
            <if test="roleCode != null">role_code = #{roleCode},</if>
            <if test="description != null">description = #{description},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM sys_role WHERE id = #{id}
    </delete>

</mapper>
